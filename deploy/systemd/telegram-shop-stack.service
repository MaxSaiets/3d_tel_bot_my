[Unit]
Description=Telegram Shop Full Docker Stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/telegram-shop
RemainAfterExit=true
ExecStart=/usr/bin/docker compose -f docker-compose.full.yml up -d --build
ExecStop=/usr/bin/docker compose -f docker-compose.full.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
