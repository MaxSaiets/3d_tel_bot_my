BOT_TOKEN=your_telegram_bot_token
WEBHOOK_BASE_URL=https://your-domain.example
WEBHOOK_SECRET=replace_with_long_random_secret
WEBHOOK_PATH=/telegram/webhook
WEBAPP_URL=https://your-webapp.example
ADMIN_GROUP_ID=-1001234567890
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/telegram_shop

CRM_PROVIDER=espocrm
CRM_URL=https://legacy-placeholder.invalid/orders
CRM_TOKEN=legacy-placeholder-token
CRM_TIMEOUT_SECONDS=10
CRM_MAX_RETRIES=3

ESPOCRM_BASE_URL=https://crm.your-domain.example
ESPOCRM_API_KEY=replace_with_espocrm_api_key
ESPOCRM_ORDER_ENTITY=Lead
ESPOCRM_DEFAULT_STATUS=New

NOVA_POSHTA_ENABLED=true
NOVA_POSHTA_API_URL=https://api.novaposhta.ua/v2.0/json/
NOVA_POSHTA_API_KEY=replace_with_np_api_key
NOVA_POSHTA_AUTO_CREATE_TTN=false
NP_SENDER_REF=
NP_SENDER_CONTACT_REF=
NP_SENDER_ADDRESS_REF=
NP_SENDER_CITY_REF=
NP_SENDER_PHONE=

CORS_ALLOW_ORIGINS=https://your-webapp.example,https://web.telegram.org
API_ORDER_RATE_LIMIT_PER_MINUTE=30
LOG_LEVEL=INFO
